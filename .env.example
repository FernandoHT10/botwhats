# Ruta al archivo de credenciales de Google Cloud (Service Account)
# Descárgalo desde Google Cloud Console y colócalo en la raíz del proyecto.
# Ver README.md para instrucciones detalladas.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account.json

# ID del Google Calendar donde se agendarán las citas.
# Normalmente es tu correo de Gmail o el ID del calendario compartido.
GOOGLE_CALENDAR_ID=tu-correo@gmail.com
